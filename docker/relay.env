# Shogun Relay Configuration for Docker Container
# This file is automatically copied to /app/relay/.env during container build

# Relay Server Configuration
RELAY_HOST=0.0.0.0
RELAY_PORT=8765
RELAY_STORE=true
RELAY_PATH=public
RELAY_QR=false
RELAY_NAME=Shogun-Relay-Docker
RELAY_PEERS=http://127.0.0.1:8765/gun
RELAY_PROTECTED=false

# Admin Authentication
ADMIN_PASSWORD=shogun2025

# IPFS Configuration (container-internal)
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080
IPFS_API_TOKEN=
IPFS_API_KEY=

# Performance Tuning for Containers
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=512

# Logging Configuration
LOG_LEVEL=info
VERBOSE_LOGGING=false 

DISABLE_RADISK=false


# x402 Payment Configuration
WALLET_ADDRESS=
# Facilitator URL: leave empty to use local facilitator, or set to external URL
# Local facilitator will be available at http://localhost:8765/api/v1/x402-facilitator
FACILITATOR_URL=
# Private key for EVM networks (Base, Base Sepolia, Ethereum)
# Required for local facilitator to settle payments
# Use EVM_PRIVATE_KEY or WALLET_PRIVATE_KEY (both work)
EVM_PRIVATE_KEY=
# Optional: Private key for Solana networks (for SVM support)
SVM_PRIVATE_KEY=
# Optional: Custom RPC URL for Solana
SVM_RPC_URL=

# Relay User Authentication (GunDB)
RELAY_USER=relay_admin
RELAY_PASSWORD=shogun2025
